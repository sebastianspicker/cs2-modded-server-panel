{
  "name": "cs2panel",
  "version": "1.0.0",
  "description": "Node.js/Express web panel to control and monitor modded Counter-Strike 2 servers via RCON.",
  "main": "app.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastianspicker/cs2-modded-server-panel.git"
  },
  "bugs": {
    "url": "https://github.com/sebastianspicker/cs2-modded-server-panel/issues"
  },
  "homepage": "https://github.com/sebastianspicker/cs2-modded-server-panel#readme",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "format:shell": "./scripts/format.sh",
    "validate": "./scripts/validate.sh",
    "lint": "eslint .",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "test": "node --test",
    "ci": "npm run format:check && npm run lint && npm test && npm run validate -- --require-docker"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^8.6.0",
    "connect-redis": "^7.1.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "redis": "^4.7.1",
    "rcon-srcds": "^2.0.2"
  },
  "devDependencies": {
    "eslint": "^9.19.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "overrides": {
    "minimatch@^3.0.2": "3.1.4",
    "minimatch@^5.1.2": "5.1.8",
    "qs": "6.15.0"
  }
}
