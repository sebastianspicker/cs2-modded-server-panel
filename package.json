{
  "name": "cs2panel",
  "version": "1.0.0",
  "description": "Node.js/Express web panel to control and monitor modded Counter-Strike 2 servers via RCON.",
  "main": "app.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastianspicker/cs2-modded-server-panel.git"
  },
  "bugs": {
    "url": "https://github.com/sebastianspicker/cs2-modded-server-panel/issues"
  },
  "homepage": "https://github.com/sebastianspicker/cs2-modded-server-panel#readme",
  "scripts": {
    "start": "npm run build:client && tsx app.ts",
    "dev": "npm run build:client && tsx watch app.ts",
    "dev:client": "esbuild public/ts/console.ts --bundle --outfile=public/js/console.js --target=es2020 --watch",
    "build": "tsc && npm run build:client",
    "build:client": "esbuild public/ts/console.ts --bundle --outfile=public/js/console.js --target=es2020",
    "start:prod": "tsc && npm run build:client && node dist/app.js",
    "format:shell": "./scripts/format.sh",
    "validate": "./scripts/validate.sh",
    "lint": "eslint .",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.client.json",
    "test": "tsc && node --test --test-force-exit --test-timeout 120000 dist/test/*.test.js",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run build:client && npm test && npm run validate -- --require-docker"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "connect-redis": "^7.1.0",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "rcon-srcds": "^2.0.2",
    "redis": "^4.7.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jquery": "^4.0.0",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "minimatch@^3.0.2": "3.1.4",
    "minimatch@^5.1.2": "5.1.8",
    "qs": "6.15.0"
  }
}
